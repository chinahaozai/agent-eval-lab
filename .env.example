# ─────────────────────────────────────────────────────────────
#  LLM Provider 配置
#  使用方法: cp .env.example .env，然后填写下面三项必填变量。
#  本项目统一走 OpenAI 兼容接口，任选一个 provider 即可。
# ─────────────────────────────────────────────────────────────

# 必填三项（从下面任选一组 provider 示例填进来）：
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# ── Provider 配置示例（价格/端点以各官网为准，可能变动）──

# 【DeepSeek】国内直连、便宜，推荐起步（deepseek-chat 为旧名，2026-07-24 弃用，等价于 deepseek-v4-flash）
# LLM_API_KEY=sk-你的key
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-v4-flash

# 【通义千问 Qwen】阿里，国内直连
# LLM_API_KEY=sk-你的key
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# 【OpenAI】需海外网络
# LLM_API_KEY=sk-你的key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# 【Claude / Anthropic】需海外网络，使用其 OpenAI 兼容端点（beta）
# LLM_API_KEY=sk-ant-你的key
# LLM_BASE_URL=https://api.anthropic.com/v1/
# LLM_MODEL=claude-3-5-sonnet-latest
